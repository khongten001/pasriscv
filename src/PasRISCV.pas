     hlit,hdist,hclen,i,num,length,clen,Symbol,Prev:TPasRISCVUInt32;
 begin
  New(CodeTree);
  New(Lengths);
  try
   FillChar(CodeTree^,sizeof(TTree),TPasRISCVRawByteChar(#0));
   FillChar(Lengths^,sizeof(TLengths),TPasRISCVRawByteChar(#0));
