 NewPath:=ComposePath(aNewFile.fPath,aNewName);
 if fpRename(PAnsiChar(Path),PAnsiChar(NewPath))<0 then begin
  result:=-POSIXErrorCodeToP9ErrorCode(fpGetErrNo);
