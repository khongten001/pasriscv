begin
 inherited Create;
 fNodeID:=0;
 fParentNodeID:=0;
 fLookupCount:=0;
 fName:='';
 fPath:='';
 fIsDirectory:=false;
end;

destructor TPasRISCV.TVirtIOFSDevice.TNodeEntry.Destroy;
begin
 fName:='';
 fPath:='';
 inherited Destroy;
end;

