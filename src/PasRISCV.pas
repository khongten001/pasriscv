function TPasRISCV.THART.TJustInTimeCompiler.MapGuestToHostVectorRegister(const aGuestVReg:TPasRISCVUInt32;const aFlags:TPasRISCVUInt8):TPasRISCVUInt8;
var HostRegister:TPasRISCVUInt8;
begin

 inc(fLRUCounter);

 // Already mapped?
