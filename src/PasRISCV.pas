 end;
 HostRS1:=MapGuestToHostIntRegister(RS1,REG_SRC);
 HostRS2:=MapGuestToHostIntRegister(RS2,REG_SRC);
 HostRD:=MapGuestToHostIntRegister(RD,REG_DST);
 EmitNativeCLMULR(HostRD,HostRS1,HostRS2);
 result:=true;
end;
