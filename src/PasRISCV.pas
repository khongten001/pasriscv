    NaNFixup,InfFixup,ZeroSubFixup,ZeroFixup,
    NegNormFixup,NegSubFixup,NegZeroFixup,NegInfFixup,QNaNFixup,
    Done1,Done2,Done3,Done4,Done5,Done6,Done7,Done8,Done9:TPasRISCVUInt32;
begin
 TempReg1:=ClaimHostIntRegister;
 TempReg2:=ClaimHostIntRegister;
 // MOVQ TempReg1, xmm (raw float64 bits)
 EmitSSE2MovXMMToGPR(TempReg1,aHostFPUSrc,true);
 // abs = clear sign bit via shift trick
 EmitMOVRegReg(aHostIntDest,TempReg1,true);
 EmitShiftRegImm(SHIFT_SHL,aHostIntDest,1,true);
 EmitShiftRegImm(SHIFT_SHR,aHostIntDest,1,true);
 // Check NaN/Inf: CMP abs, $7ff0000000000000
 EmitMOVRegImm64(TempReg2,TPasRISCVUInt64($7ff0000000000000));
 Emit2RegOp(X86_CMP,aHostIntDest,TempReg2,true);
 EmitJccRel32(CC_A,0);
 NaNFixup:=fTemporaryCodeSize-4;
 EmitJccRel32(CC_E,0);
 InfFixup:=fTemporaryCodeSize-4;
 // Check zero/subnormal: CMP abs, $0010000000000000
 EmitMOVRegImm64(TempReg2,TPasRISCVUInt64($0010000000000000));
 Emit2RegOp(X86_CMP,aHostIntDest,TempReg2,true);
 EmitJccRel32(CC_B,0);
 ZeroSubFixup:=fTemporaryCodeSize-4;
 // Normal: check sign
 EmitTEST(TempReg1,TempReg1,true);
 EmitJccRel32(CC_S,0);
 NegNormFixup:=fTemporaryCodeSize-4;
 EmitMOVRegImm32(aHostIntDest,$40); // bit 6: +normal
 EmitJmpRel32(0);
 Done1:=fTemporaryCodeSize-4;
 PatchJmpRel32(NegNormFixup);
 EmitMOVRegImm32(aHostIntDest,$02); // bit 1: -normal
 EmitJmpRel32(0);
 Done2:=fTemporaryCodeSize-4;
 // .zero_or_sub:
 PatchJmpRel32(ZeroSubFixup);
 EmitTEST(aHostIntDest,aHostIntDest,true);
 EmitJccRel32(CC_E,0);
 ZeroFixup:=fTemporaryCodeSize-4;
 // Subnormal: check sign
 EmitTEST(TempReg1,TempReg1,true);
 EmitJccRel32(CC_S,0);
 NegSubFixup:=fTemporaryCodeSize-4;
 EmitMOVRegImm32(aHostIntDest,$20); // bit 5: +subnormal
 EmitJmpRel32(0);
 Done3:=fTemporaryCodeSize-4;
 PatchJmpRel32(NegSubFixup);
 EmitMOVRegImm32(aHostIntDest,$04); // bit 2: -subnormal
 EmitJmpRel32(0);
 Done4:=fTemporaryCodeSize-4;
 // .zero:
 PatchJmpRel32(ZeroFixup);
 EmitTEST(TempReg1,TempReg1,true);
 EmitJccRel32(CC_S,0);
 NegZeroFixup:=fTemporaryCodeSize-4;
 EmitMOVRegImm32(aHostIntDest,$10); // bit 4: +zero
 EmitJmpRel32(0);
 Done5:=fTemporaryCodeSize-4;
 PatchJmpRel32(NegZeroFixup);
 EmitMOVRegImm32(aHostIntDest,$08); // bit 3: -zero
 EmitJmpRel32(0);
 Done6:=fTemporaryCodeSize-4;
 // .inf:
 PatchJmpRel32(InfFixup);
 EmitTEST(TempReg1,TempReg1,true);
 EmitJccRel32(CC_S,0);
 NegInfFixup:=fTemporaryCodeSize-4;
 EmitMOVRegImm32(aHostIntDest,$80); // bit 7: +infinity
 EmitJmpRel32(0);
 Done7:=fTemporaryCodeSize-4;
 PatchJmpRel32(NegInfFixup);
 EmitMOVRegImm32(aHostIntDest,$01); // bit 0: -infinity
 EmitJmpRel32(0);
 Done8:=fTemporaryCodeSize-4;
 // .nan: check quiet bit (bit 51 = $0008000000000000)
 PatchJmpRel32(NaNFixup);
 EmitMOVRegImm64(TempReg2,TPasRISCVUInt64($0008000000000000));
 EmitTEST(aHostIntDest,TempReg2,true);
 EmitJccRel32(CC_NE,0);
 QNaNFixup:=fTemporaryCodeSize-4;
 EmitMOVRegImm32(aHostIntDest,$100); // bit 8: sNaN
 EmitJmpRel32(0);
 Done9:=fTemporaryCodeSize-4;
 PatchJmpRel32(QNaNFixup);
 EmitMOVRegImm32(aHostIntDest,$200); // bit 9: qNaN
 // .done: (qNaN falls through)
 PatchJmpRel32(Done1);
 PatchJmpRel32(Done2);
 PatchJmpRel32(Done3);
 PatchJmpRel32(Done4);
 PatchJmpRel32(Done5);
 PatchJmpRel32(Done6);
 PatchJmpRel32(Done7);
 PatchJmpRel32(Done8);
 PatchJmpRel32(Done9);
 FreeHostIntRegister(TempReg1);
 FreeHostIntRegister(TempReg2);
end;
{$endif}

{$if defined(PasRISCVJustInTimeCompilerFPU) and defined(PasRISCVJustInTimeCompilerFMA)}
function TPasRISCV.THART.TJustInTimeCompilerX8664.IntrinsicFMADDS(const aInstruction:TPasRISCVUInt32;const aParameter0,aParameter1,aParameter2,aParameter3:TPasRISCVUInt64):Boolean;
var FRD,FRS1,FRS2,FRS3:TFPURegister;
    HostFRD,HostFRS1,HostFRS2,HostFRS3,ScratchXMM:TPasRISCVUInt8;
{$ifdef PasRISCVJustInTimeCompilerUseRealFMA}
    VexByte1,VexByte2,FMADst:TPasRISCVUInt8;
{$else}
    ScratchXMM2,ScratchXMM3:TPasRISCVUInt8;
{$endif}
    RM,RMTmp:TPasRISCVUInt8;
begin
{$ifdef PasRISCVJustInTimeCompilerUseRealFMA}
 if not fHasFMA3 then begin
  result:=false;
  exit;
 end;
{$endif}
 FRD:=TFPURegister(aParameter0);
 FRS1:=TFPURegister(aParameter1);
 FRS2:=TFPURegister(aParameter2);
 FRS3:=TFPURegister(aParameter3);
 HostFRS1:=MapGuestToHostFPURegister(FRS1,REG_SRC);
 HostFRS2:=MapGuestToHostFPURegister(FRS2,REG_SRC);
 HostFRS3:=MapGuestToHostFPURegister(FRS3,REG_SRC);
 HostFRD:=MapGuestToHostFPURegister(FRD,REG_DST);
 RM:=(aInstruction shr 12) and 7;
 if RM<=4 then begin
  RMTmp:=ClaimHostIntRegister;
  EmitSaveAndSetRoundingMode(RM,RMTmp);
  FreeHostIntRegister(RMTmp);
 end;
{$ifdef PasRISCVJustInTimeCompilerUseRealFMA}
 // VFMADD231SS: dst = vvvv*rm + dst
 // use scratch if dst aliases vvvv(frs1) or rm(frs2)
 if (HostFRD=HostFRS1) or (HostFRD=HostFRS2) then begin
  FMADst:=ClaimHostFPURegister;
 end else begin
  FMADst:=HostFRD;
 end;
 EmitFPUMov(FMADst,HostFRS3,false);
 VexByte1:=$02;
 if FMADst<8 then begin
  VexByte1:=VexByte1 or $80;
 end;
 VexByte1:=VexByte1 or $40;
 if HostFRS2<8 then begin
  VexByte1:=VexByte1 or $20;
 end;
 VexByte2:=$01;
 VexByte2:=VexByte2 or (((not HostFRS1) and $0f) shl 3);
 EmitByte(X86_VEX3);
 EmitByte(VexByte1);
 EmitByte(VexByte2);
 EmitByte(X86_VEX_VFMADD231);
 EmitModRM(3,FMADst,HostFRS2);
 if FMADst<>HostFRD then begin
  EmitFPUMov(HostFRD,FMADst,false);
  FreeHostFPURegister(FMADst);
 end;
{$else}
 // emulated: frd = frs1*frs2 + frs3 (via double promotion for single-rounding)
 ScratchXMM2:=ClaimHostFPURegister;
 EmitSSE2Op($f3,$5a,ScratchXMM2,HostFRS1);    // cvtss2sd scratch2, frs1
 ScratchXMM3:=ClaimHostFPURegister;
 EmitSSE2Op($f3,$5a,ScratchXMM3,HostFRS2);    // cvtss2sd scratch3, frs2
 EmitSSE2Op($f2,$59,ScratchXMM2,ScratchXMM3); // mulsd scratch2, scratch3 (exact)
 EmitSSE2Op($f3,$5a,ScratchXMM3,HostFRS3);    // cvtss2sd scratch3, frs3
 EmitSSE2Op($f2,$58,ScratchXMM2,ScratchXMM3); // addsd scratch2, scratch3
 FreeHostFPURegister(ScratchXMM3);
 EmitSSE2Op($f2,$5a,ScratchXMM2,ScratchXMM2); // cvtsd2ss scratch2, scratch2
 EmitFPUMov(HostFRD,ScratchXMM2,false);
 FreeHostFPURegister(ScratchXMM2);
{$endif}
 if RM<=4 then begin
  EmitRestoreRoundingMode;
 end;
 ScratchXMM:=ClaimHostFPURegister;
 EmitNaNBox32(HostFRD,ScratchXMM);
 FreeHostFPURegister(ScratchXMM);
 EmitSetFSDirty;
 result:=true;
end;

