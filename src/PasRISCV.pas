procedure TPasRISCV.TVirtIOSoundDevice.TPCMStream.ReturnBuffer(const aPCMBuffer:TPCMBuffer;const aLock:Boolean);
begin
 if assigned(aPCMBuffer) then begin
  if aLock then begin
   fBufferQueueLock.Acquire;
  end;
