procedure TPasRISCV.TRawKeyboardDevice.ModifierUp(const aModifier:TPasRISCVUInt64);
begin
 fData[ModifiersAddress]:=fData[ModifiersAddress] and not TPasRISCVUInt8(aModifier);
end;

