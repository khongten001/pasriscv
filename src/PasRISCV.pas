  BufferCurrent:=BufferBegin;
  FmtIndex:=1;
  while (TPasRISCVPtrUInt(BufferCurrent)<TPasRISCVPtrUInt(BufferEnd)) and (FmtIndex<=length(aFmt)) do begin
   ArgIndex:=FmtIndex-1;
