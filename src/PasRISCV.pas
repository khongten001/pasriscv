                     procedure DispatchPageSet(const aStartPage:TPasRISCVUInt64;const aCountPages:TPasRISCVUInt64;const aSectionIndex:TPasRISCVUInt32);
                     procedure DispatchCompact(var aEntry:TPasRISCVUInt32);
