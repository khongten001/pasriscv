         VectorSetElement(vd,SubIndex+1,32,SegmentBuffer[1]);
         VectorSetElement(vd,SubIndex+2,32,SegmentBuffer[2]);
         VectorSetElement(vd,SubIndex+3,32,SegmentBuffer[3]);
