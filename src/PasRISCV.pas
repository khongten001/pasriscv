                   TMMU=class
                    public
                     const DIRECT_ACCESS_TLB_ENTRIES=TPasRISCVUInt64(256);
                           DIRECT_ACCESS_TLB_MASK=DIRECT_ACCESS_TLB_ENTRIES-1;
