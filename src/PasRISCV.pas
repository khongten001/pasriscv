   end;
  end;
{$endif}
  p:=GetGlobalDirectMemoryAccessPointer(aPhysicalAddress,SizeOf(TPasRISCVUInt16),true,nil);
  if assigned(p) then begin
   PPasRISCVUInt16(p)^:=aValue;
   result:=true;
  end;
 end;
