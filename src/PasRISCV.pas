 EmitMemOperand(TPasRISCVUInt8(TX64Register.rRAX),aHostAddr,0);
 RetryOffset:=fTemporaryCodeSize;
 EmitMOVRegReg(HostTemp,aHostSrc,true); // temp = src (candidate)
