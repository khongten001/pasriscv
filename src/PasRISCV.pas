procedure TPasRISCV.THART.ExecuteInstructionCBOZero(const aAddress:TPasRISCVUInt64);
var Ptr:Pointer;
begin
 Ptr:=MemoryPointerTranslate(aAddress and TPasRISCVUInt64($ffffffffffffffc0),64,nil,false);
 if assigned(Ptr) then begin
  FillChar(Ptr^,64,#0);
 end;
end;

