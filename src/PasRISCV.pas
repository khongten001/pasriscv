  end;
 end;

 // Read current CSR state at JIT-compile time for validation
 SEW:=8 shl ((fHART.fState.CSR.fData[TCSR.TAddress.VTYPE] shr 3) and 7);
 case fHART.fState.CSR.fData[TCSR.TAddress.VTYPE] and 7 of
  $00:begin
   LMUL8:=8;
  end;
  $01:begin
   LMUL8:=16;
  end;
  $02:begin
   LMUL8:=32;
  end;
  $03:begin
   LMUL8:=64;
  end;
  $05:begin
   LMUL8:=1;
  end;
  $06:begin
   LMUL8:=2;
  end;
  $07:begin
   LMUL8:=4;
  end;
  else begin
