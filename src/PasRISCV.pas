    RetryOffset:TPasRISCVSizeInt;
begin
 // CAS loop: retry: MOV RAX,[addr]; MOV temp,RAX; MAXop temp,rs2; LOCK CMPXCHG [addr],temp; JNE retry
 // CAS loop with signed max: new = (old > rs2) ? old : rs2
